{
  "name": "react-chunked-upload",
  "version": "0.2.0",
  "description": "A lightweight React hook for chunked large-file uploads with pause, resume, retry, and progress support.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run --environment jsdom"
  },
  "keywords": [
    "react",
    "hook",
    "upload",
    "chunk",
    "chunked-upload",
    "file-upload",
    "resume",
    "large-file",
    "chunked-file-upload",
    "large-file-upload",
    "resumable-upload",
    "react-upload",
    "react-file-upload",
    "upload-hook",
    "file-uploader",
    "blob",
    "multipart",
    "pause",
    "retry"
  ],
  "author": "Kim Hyeong Kyeom <goww1357@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "homepage": "https://github.com/Kyeom1997/react-chunked-upload#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kyeom1997/react-chunked-upload.git"
  },
  "bugs": {
    "url": "https://github.com/Kyeom1997/react-chunked-upload/issues"
  }
}
